Options -MultiViews
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]
Header always unset X-Frame-Options
Header always unset Content-Security-Policy
Header always set Content-Security-Policy "upgrade-insecure-requests; default-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data: https:; frame-src 'self' blob: data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; connect-src 'self' https:; worker-src 'self' blob: https:; style-src 'self' 'unsafe-inline' https:;"
Header set Referrer-Policy "no-referrer-when-downgrade"

# Rutas limpias: redirige todo a index.html si no es un archivo o carpeta real
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# Cache headers para assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On

  # Imágenes
  ExpiresByType image/webp   "access plus 1 year"
  ExpiresByType image/jpeg   "access plus 1 year"
  ExpiresByType image/png    "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"

  # CSS y JS (Vite ya les pone hash en el nombre, cacheable agresivamente)
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"

  # Fuentes
  ExpiresByType font/woff2  "access plus 1 year"
  ExpiresByType font/woff   "access plus 1 year"
  ExpiresByType font/ttf    "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Para archivos con hash en el nombre (output de Vite: *.js, *.css en /assets/)
  <FilesMatch "\.(js|css|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Para imágenes (pueden cambiar sin hash)
  <FilesMatch "\.(webp|jpg|jpeg|png|svg)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML nunca cachear agresivamente
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
