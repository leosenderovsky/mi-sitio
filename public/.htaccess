Options -MultiViews
RewriteEngine On

# Redirigir HTTP → HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

# Headers de seguridad
Header always unset X-Frame-Options
Header always unset Content-Security-Policy
Header always set Content-Security-Policy "upgrade-insecure-requests; default-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data: https:; frame-src 'self' blob: data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; connect-src 'self' https:; worker-src 'self' blob: https:; style-src 'self' 'unsafe-inline' https:;"
Header set Referrer-Policy "no-referrer-when-downgrade"

# Fallback SPA: redirige cualquier ruta no-archivo y no-carpeta a index.html
# (necesario para que React Router funcione en Hostinger con Apache)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# Compresión gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache por tipo MIME
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html            "access plus 0 seconds"
  ExpiresByType text/css             "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/avif           "access plus 1 year"
  ExpiresByType image/webp           "access plus 1 year"
  ExpiresByType image/jpeg           "access plus 1 year"
  ExpiresByType image/png            "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 year"
  ExpiresByType font/woff2           "access plus 1 year"
  ExpiresByType font/woff            "access plus 1 year"
  ExpiresByType font/ttf             "access plus 1 year"
  ExpiresByType application/pdf      "access plus 1 month"
</IfModule>

# Cache-Control por extensión
<IfModule mod_headers.c>
  # Assets con hash en nombre (output de Vite) → caché agresivo
  <FilesMatch "\.(css|js|mjs|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Imágenes con y sin hash → caché largo pero no immutable
  <FilesMatch "\.(avif|webp|jpg|jpeg|png|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML → nunca cachear
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
